{
    "manifest_version": 3,
    "name": "MoeKoe Taskbar Lyrics",
    "version": "0.3.0",
    "description": "在 Windows 任务栏上显示逐字高亮歌词，支持卡拉OK效果、翻译显示和播放控制",
    "author": {
        "name": "Yngu196",
        "url": "https://github.com/Yngu196"
    },
    "plugin_id": "Taskbar-Lyrics",
    "moekoe": true,
    "minversion": "0.3.0",
    "native_launcher": "MoeKoeTaskbarLyrics.exe",
    "permissions": [
        "nativeMessaging"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "任务栏歌词设置"
    },
    "icons": {
        "16": "../icons/icon16.png",
        "48": "../icons/icon48.png",
        "128": "../icons/icon128.png"
    }
}

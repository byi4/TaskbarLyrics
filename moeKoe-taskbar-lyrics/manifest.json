{"manifest_version": 3, "name": "Windows任务栏歌词插件", "plugin_id": "Taskbar-Lyrics", "version": "0.4.1", "minversion": "1.6.6", "moekoe": true, "author": {"name": "Yngu196", "url": "https://github.com/Yngu196"}, "description": "在 Windows 任务栏上显示逐字高亮歌词，支持卡拉OK效果和播放控制", "permissions": ["storage"], "moekoe_permissions": ["moekoe:nativeHost"], "moekoe_native_hosts": [{"id": "taskbar-lyrics-host", "platforms": {"win32": {"path": "MoeKoeTaskbarLyrics.exe", "args": []}}, "auto_start": true, "bridge": "native-bridge.html"}], "background": {"service_worker": "background.js"}, "action": {"default_popup": "popup.html", "default_title": "任务栏歌词设置", "default_icon": {"256": "icons/icon256.png"}}, "web_accessible_resources": [{"resources": ["icons/*"], "matches": ["<all_urls>"]}], "icons": {"256": "icons/icon256.png"}}